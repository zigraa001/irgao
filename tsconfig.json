{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false
  },
  "include": ["server.js", "src/**/*.js", "scripts/db-setup.js", "prisma/seed.js", "test/**/*.js"],
  "exclude": ["node_modules"]
}
