# IraGo environment configuration.
# Copy to `.env` (which is gitignored) and fill in real values.

# --- Hostinger MySQL connection ---------------------------------------------
# Host, user, port, and database NAME have hard-coded defaults in src/db.js, so
# the only value you MUST provide here is the password:
DB_PASSWORD=databasepassword

# The rest are OPTIONAL overrides of the src/db.js defaults. Uncomment to change.
#   DB_HOST  usually "localhost" when the Node app runs ON the same Hostinger
#            server as the database. If you connect from elsewhere, use the
#            remote host from hPanel AND allow your IP under Remote MySQL.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=databaseuser
# DB_NAME=databasename

# Optional pool/timeout tuning (sensible defaults applied if unset).
# DB_POOL_LIMIT=10
# DB_CONNECT_TIMEOUT_MS=10000

# Verbose per-query SQL logging. On by default; set to "false" to quiet it.
DB_DEBUG=true

# Port the Express server listens on.
PORT=3000

# Secret used to sign session tokens (HMAC). Generated by the env script — do not
# hand-edit unless rotating. Run once after copying this file:
#   npm run env:gen
AUTH_SECRET=

# --- First admin (env bootstrap only — no OTP signup or online password reset) -
# Set ADMIN_USER + ADMIN_PASSWORD, then run: npm run admin:bootstrap
# Passengers and operators use OTP signup; admins do not.
ADMIN_USER=admin@irago.com
ADMIN_PASSWORD=

# --- SMTP (OTP email delivery — REQUIRED) -----------------------------------
# Hostinger (irago.com mailbox): smtp.hostinger.com:465, SMTP_SECURE=true
# Gmail: smtp.gmail.com + App Password. Mailtrap for local dev.
# OTP codes are sent only via email — never logged or returned in API responses.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@irago.com
SMTP_PASS=your-hostinger-mailbox-password
SMTP_FROM="IraGo <info@irago.com>"

# --- Session cookie (HttpOnly JWT) --------------------------------------------
# AUTH_COOKIE_NAME defaults to irago_session.
# AUTH_COOKIE_TTL_SECONDS defaults to 604800 (7 days).
# Set AUTH_COOKIE_SECURE=true when serving over HTTPS (auto-enabled in production).
# AUTH_COOKIE_SECURE=false

# --- Admin panel Tailscale (recommended for production) -----------------------
# ADMIN_REQUIRE_TAILSCALE=true
# ADMIN_TAILSCALE_ALLOW_LOCAL=false
# TRUST_PROXY=true
