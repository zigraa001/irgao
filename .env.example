# IraGo environment configuration.
# Copy to `.env` (which is gitignored) and fill in real values.

# --- Hostinger MySQL connection ---------------------------------------------
# Get these from hPanel > Databases > MySQL Databases.
#   DB_HOST     usually "localhost" when the Node app runs ON the same
#               Hostinger server as the database. If you connect from elsewhere,
#               use the remote host shown in hPanel AND add your IP under
#               hPanel > Databases > Remote MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=databaseuser
DB_PASSWORD=databasepassword
DB_NAME=databasename

# Optional pool/timeout tuning (sensible defaults applied if unset).
# DB_POOL_LIMIT=10
# DB_CONNECT_TIMEOUT_MS=10000

# Verbose per-query SQL logging. On by default; set to "false" to quiet it.
DB_DEBUG=true

# Port the Express server listens on.
PORT=3000

# Secret used to sign session tokens (HMAC). MUST be set to a long random
# string in production; if unset the server falls back to an insecure dev
# secret and logs a warning. Generate one with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
