# IraGo environment configuration.
# Copy to `.env` (which is gitignored) and fill in real values.

# Which database engine Prisma talks to:
#   mysql  -> Hostinger MySQL (default / production)
#   sqlite -> local file-based DB for development/testing
# After changing this, run `npm run db:setup` to re-sync the Prisma schema.
DATABASE_PROVIDER=mysql

# Connection string used by Prisma (datasource `url`).
#
# --- Hostinger MySQL (default / production) ---
# Get HOST, USER, PASSWORD, and DATABASE from hPanel -> Databases -> MySQL.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# --- Local SQLite override (uncomment BOTH lines for local dev) ---
# DATABASE_PROVIDER=sqlite
# DATABASE_URL="file:./dev.db"

# Port the Express server listens on.
PORT=3000

# Secret used to sign session tokens (HMAC). MUST be set to a long random
# string in production; if unset the server falls back to an insecure dev
# secret and logs a warning. Generate one with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
