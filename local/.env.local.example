# Local-only overrides — copy to local/.env.local (gitignored).
# Loaded by scripts/local/* before calling the main app scripts.

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=irago
DB_PASSWORD=irago_local
DB_NAME=irago
ZONES_DB_NAME=irago_zones
DB_DEBUG=false

PORT=3002

# First admin (pure auth — run npm run local:bootstrap after setup)
ADMIN_USER=admin@irago.com
ADMIN_PASSWORD=change-me-local-admin

# SMTP required for OTP — use Mailtrap locally to catch messages in a web inbox.
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=

# --- Admin panel via Tailscale -----------------------------------------------
# When true, /api/admin/* only accepts Tailscale IPs or Tailscale Serve identity.
ADMIN_REQUIRE_TAILSCALE=true
# Allow localhost admin API while developing (still use Tailscale URL in production).
ADMIN_TAILSCALE_ALLOW_LOCAL=true
# Required when using `tailscale serve` as reverse proxy.
TRUST_PROXY=true
